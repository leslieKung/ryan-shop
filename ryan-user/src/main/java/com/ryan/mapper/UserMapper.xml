<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ryan.com.ryan.mapper.UserMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.ryan.com.ryan.model.UserDO">
        <id column="id" property="id" />
        <result column="name" property="name" />
        <result column="pwd" property="pwd" />
        <result column="avatar" property="avatar" />
        <result column="sex" property="sex" />
        <result column="points" property="points" />
        <result column="now_money" property="nowMoney" />
        <result column="phone" property="phone" />
        <result column="mail" property="mail" />
        <result column="vip" property="vip" />
        <result column="secret" property="secret" />
        <result column="last_login_time" property="lastLoginTime" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, name, pwd, avatar, sex, points, now_money, phone, mail, vip, secret, last_login_time, create_time, update_time
    </sql>

</mapper>
